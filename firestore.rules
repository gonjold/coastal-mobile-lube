rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // BOOKINGS COLLECTION
    // Public: can CREATE new bookings (form submissions)
    // Admin only: can READ, UPDATE, DELETE
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // SERVICES COLLECTION (pricing map)
    // Public: can READ (for displaying pricing on site)
    // Admin only: can CREATE, UPDATE, DELETE
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // SERVICE CATEGORIES COLLECTION
    // Public: can READ (for displaying category nav on site)
    // Admin only: can CREATE, UPDATE, DELETE
    match /serviceCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // CATCH-ALL: deny everything else
    // Any collection not explicitly defined above is locked down
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
