rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // BOOKINGS COLLECTION
    // Public: can CREATE new bookings (form submissions)
    // Admin only: can READ, UPDATE, DELETE
    match /bookings/{bookingId} {
      allow create: if true;
      // Public phone-lookup: allow list queries with a limit (used by "Been here before?" feature)
      allow list: if request.query.limit != null && request.query.limit <= 10;
      allow get, update, delete: if request.auth != null;
    }

    // SERVICES COLLECTION (pricing map)
    // Public: can READ (for displaying pricing on site)
    // Admin only: can CREATE, UPDATE, DELETE
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // SERVICE CATEGORIES COLLECTION
    // Public: can READ (for displaying category nav on site)
    // Admin only: can CREATE, UPDATE, DELETE
    match /serviceCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // QR CODES COLLECTION
    // Public: can READ (redirect handler needs slug lookup)
    // Admin only: can WRITE
    match /qrCodes/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // QR SCANS COLLECTION
    // Public: can CREATE (scan log fire-and-forget from redirect handler)
    // Admin only: can READ
    // Immutable: no update or delete
    match /qrScans/{id} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // CATCH-ALL: deny everything else
    // Any collection not explicitly defined above is locked down
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
