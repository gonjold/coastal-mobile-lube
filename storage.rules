rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // FDACS-required PDFs: 7-year retention via GCS lifecycle (set separately).
    // Cloud Functions write via Admin SDK (bypasses these rules).
    // Reads gated by Firestore-stored signed URLs; direct Storage reads disallowed.
    match /fdacs-pdfs/{allPaths=**} {
      allow read, write: if false;
    }

    // Customer signatures captured on-site by the tech app. Tiny PNGs only.
    match /signatures/{bookingId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/png');
    }

    // Estimate-acceptance signatures (A1). Written by the Cloud Function that
    // mints the customer-facing acceptance flow; read is public because the
    // acceptance API validates an HMAC token before returning the URL.
    match /signatures/estimates/{estimateId}/{revision} {
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider == 'custom';
      allow read: if true;
    }

    // Mid-job photos captured by the tech app (before/after/diagnostic). 5MB cap, image/* only.
    match /photos/{bookingId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny for everything else. Add specific match blocks above as needed.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
