# =================================================================
# Coastal Mobile Lube — environment variables
# Copy to .env.local for development; mirror to Netlify for prod.
# =================================================================

# ============= FIREBASE (CLIENT) =============
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ============= FIREBASE ADMIN (SERVER) =============
# Either set the JSON blob...
FIREBASE_ADMIN_KEY_JSON=
# ...or set these three (matches the existing pattern in src/lib/firebase-admin.ts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ============= AUTH COOKIE (Phase 1, WO-P1-1B) =============
# Random secrets used by next-firebase-auth-edge to sign session cookies.
# Generate with: openssl rand -hex 32
# Two keys are required to support rotation (use both; rotate KEY_2 first).
AUTH_COOKIE_SIGNATURE_KEY_1=
AUTH_COOKIE_SIGNATURE_KEY_2=

# ============= CLOVER (Phase 1, WO-P1-1D) =============
# Sandbox values — get from https://www.clover.com/developer-home after creating an app
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_ENVIRONMENT=sandbox  # 'sandbox' or 'production'
CLOVER_API_BASE_URL=https://apisandbox.dev.clover.com  # production: https://api.clover.com

# Per-merchant (set after OAuth grant)
CLOVER_MERCHANT_ID=
CLOVER_ACCESS_TOKEN=
CLOVER_REFRESH_TOKEN=
CLOVER_TOKEN_EXPIRES_AT=  # ISO timestamp

# REST Pay Display (Flex path) — set when device pairs
CLOVER_DEVICE_ID=
CLOVER_REMOTE_APP_ID=

# Webhooks
CLOVER_WEBHOOK_SECRET=
