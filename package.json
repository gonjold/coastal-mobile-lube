{
  "name": "coastal-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:marketing": "npm run build -w apps/marketing",
    "build:ops": "npm run build -w apps/ops",
    "build:all": "npm run build:marketing && npm run build:ops",
    "typecheck:all": "npm run typecheck -w apps/marketing && npm run typecheck -w apps/ops",
    "migrate": "tsx scripts/migrations/run.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
